/gforth <<
[/benchgc4 /brainless /brew /cd16sim /fcp /lexex]
{<< /bench rot >> begin
  << bench {middle} >> begin bench results 7 get end
end } forall
>> def

/benchgc4   {/benchgc4   swap middlelog} def
/brainless {/brainless swap middlelog} def
/brew      {/brew      swap middlelog} def
/cd16sim   {/cd16sim   swap middlelog} def
/fcp       {/fcp       swap middlelog} def
/lexex     {/lexex     swap middlelog} def

%[c7:~/forth/appbench-1.0:24560] FORTH="bigforth -d 16M -r 8k -e " BENCH="brainless cd16sim fcp lexex" ./run
/bigforth <<
[1.228 1.288 1.300 ] brainless
[30.106 30.142 30.142 ] brew
[28.738 28.742 28.870 ] cd16sim
[1.592 1.624 1.624 ] fcp
[29.146 30.602 30.766 ] lexex
>> def
%[c7:~/forth/appbench-1.0:24566] FORTH="iforth" BENCH="benchgc4 cd16sim" ./run
/iforth <<
[0.364 0.372 0.380 ] benchgc4
[0.836 0.844 0.844 ] cd16sim
>> def
%[c7:~/forth/appbench-1.0:24567] FORTH="spf4  ../setup/spf.f " BENCH="cd16sim fcp" ./run
/spf4 <<
[1.156 1.184 1.220 ] cd16sim
[2.784 2.784 2.788 ] fcp
>> def
%[c7:~/forth/appbench-1.0:24569] FORTH="vfxlin : ms@ ticks ; : 0. 0 0 ;" BENCH="cd16sim fcp lexex" ./run
/vfxlin <<
[0.480 0.488 0.492 ] brainless
[0.880 0.900 0.908 ] cd16sim
[1.000 1.004 1.008 ] fcp
[14.613 14.621 14.645 ] lexex
>> def

/rdict <<
    /bigforth bigforth
    /gforth gforth
    /iforth iforth
    /spf4 spf4
    /vfxlin vfxlin
>> def

/machine /c7-32 def

/cpu
<<
/b2 (21264B)
