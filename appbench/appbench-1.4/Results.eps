/ppc64 (PPC64)
/ppc64-32 (PPC)
>> machine get def

1 setlinejoin
0 setlinecap
0 0 translate
0.3 setlinewidth

/benchs [/benchgc4 /brainless /brew /cd16sim /fcp /lexex] def
/forths [/iforth /bigforth /gforth /vfxlin /spf4] def

[] 0 setdash
0 setgray

/xright benchs length 1 sub def

0.5 setlinewidth
xbase ytop mt
xbase ybase lt
xright ybase lt
stroke

%xright ybase mt 3 2 rmoveto (gforth version) yjcenter show
xbase ytop mt 0 6 rmoveto (speed) xjcenter show

xbase ytop mt 30 6 rmoveto arch show 3 0 rmoveto cpu show

/str 20 string def

/xticklen1 -2 def
/xticklen {xticklen1 /xticklen1 -13 xticklen1 sub store} def
%name --
/xtick {0 setgray 0.5 setlinewidth str cvs 0 xticklen rlineto 0 -2 rmoveto xjcenter yjtop show stroke } def
%0 benchs {str cvs over xtick 1 add} forall drop

%r --
/ytick { dup log neg dup ybase le
    {xbase exch mt  -2 0 rlineto -2 0 rmoveto str cvs xjright yjcenter show}
    {drop drop}
    ifelse
} def
5.6 ytick
4 ytick
2.8 ytick
2 ytick
1.4 ytick
1 ytick
0.7 ytick
0.5 ytick
0.3 ytick
0.2 ytick
stroke

%name --
/label {gsave 6 setlinewidth dup setncolor 6 0 rlineto
        currentpoint stroke grestore moveto
        1 -3 rmoveto 0 setgray str cvs show 8 3 rmoveto
} def

4 ytop mt
forths {
    gsave label grestore 0 -10 rmoveto
} forall

barwidth setlinewidth
0 ybase mt
benchs {<< /bench rot >> begin
    gsave barwidth 3 mul 0 rmoveto bench xtick grestore
    forths {<< /forth rot >> begin
	barwidth 0 rmoveto
	rdict forth get bench xget
	dup error eq
	    {drop}
	    {forth setncolor rdict /gforth get bench get sub bar}
	ifelse
    } forall
    gap
} forall
