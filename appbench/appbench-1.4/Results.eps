%!PS-Adobe-2.0 EPSF-1.2
%%BoundingBox: 33 410 260 683
%!PS-Adobe-2.0 EPSF-1.2
%%Pages: 1 1
%%DocumentFonts: Helvetica
%%EndComments
% -*- ps -*-
/drop {pop} def
/swap {exch} def
/over {1 index} def
/nip {swap drop} def
/rot {3 2 roll} def
/3roll {4 3 roll} def
/error /error def
/xtf {barwidth mul 8.4 mul 50 add} def
/ytf {-150 mul 550 add} def
/tf {exch xtf exch ytf} def
/mt {tf moveto} def
/lt {tf lineto} def
/sl {/linepoint {mt} store} def           %start line ( -- )
/lp {linepoint /linepoint {lt} store} def %line point ( x y -- )
/xbase 0 def
/ybase 0.8 def
/ytop -0.8 def
/barwidth 5 def %points
/ylt {currentpoint drop swap ytf lineto} def
/colors <</gforth {0   0   0}
          /bigforth {1   0  0 }
	  /iforth {0.7 0  0.7}
	  /spf4 {0  1 0}
	  /vfxlin {0  0  1}
>> def
/setncolor {colors swap get exec setrgbcolor} def
%height -- 
/bar {gsave ylt stroke grestore} def
/gap {barwidth 2 mul 0 rmoveto} def
newpath /Helvetica findfont 9 scalefont setfont
/xjright {dup stringwidth pop neg 0 rmoveto} def
/xjcenter {dup stringwidth pop 2 div neg 0 rmoveto} def
/yjtop {0 -7 rmoveto} def
/yjcenter {0 -3.5 rmoveto} def
%str xtick[12]
/xtick1 { 0 setgray 0.5 setlinewidth
          5 0 rmoveto 0 -2 rlineto 0 -2 rmoveto xjcenter yjtop show stroke
          /xtick /xtick1 load def } def
/xtick2 { 0 setgray 0.5 setlinewidth 
          5 0 rmoveto 0 -11 rlineto 0 -2 rmoveto xjcenter yjtop show stroke
          /xtick /xtick1 load def } def
/xtick //xtick1 def

%r1 r2 -- bool
/xgt {over error eq
    {drop drop true}
    {dup error eq { drop drop false } { gt } ifelse }
    ifelse
} def

%n1 n2 -- n
/min {over over xgt {swap} if drop} def

%array -- n
/minarray {dup 1 get swap {min} forall} def

%dict -- r
/mindict {1e38 swap {nip min} forall} def

%dictdict -- r
/mindictdict {1e38 swap {nip mindict min} forall} def

%dict key -- obj
/xget {over over known {get} {drop drop error} ifelse} def

/err11 { over error ne swap if } def

/err20 { rot rot over error eq over error eq or not 3roll {drop drop} ifelse }
def

%the middle element
%that's the median if the array is sorted and the length is odd
%array -- obj
/middle { {dup length 1 sub 2 div cvi get} err11 } def
/middlelog {middle log} def

%obj1 obj2 proc -- obj3
%propagate error
/err21 { << /proc rot >> begin 
    over error eq over error eq or {drop drop error}  /proc load end
    ifelse
} def

%r1 r2 -- r3
/xdiv { {div} err21 } def

%/xdiv { over error eq over error eq or {drop drop error} { div } ifelse } def

%array -- r
/logsum { 0 swap { { log add } err21 } forall } def

%array -- r
/logmean { dup logsum swap length xdiv } def

/benchgc4   {drop} def
/brainless {drop} def
/brew      {drop} def
/cd16sim   {drop} def
/fcp       {drop} def
/lexex     {drop} def

/onegcc {swap logmean} def

/onegforth {<< rot {} forall >> mindict} def

